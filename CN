Simple Link-State Routing Program

# simple graph (network)
graph = {
    1: {2:1, 3:4},
    2: {1:1, 3:2, 4:5},
    3: {1:4, 2:2, 4:1},
    4: {2:5, 3:1}
}

# source router
start = 1

# distances
dist = {node: float('inf') for node in graph}
dist[start] = 0

visited = []

while len(visited) < len(graph):
    # find minimum distance node
    min_node = None
    for node in graph:
        if node not in visited:
            if min_node is None or dist[node] < dist[min_node]:
                min_node = node

    visited.append(min_node)

    # update neighbors
    for neighbor in graph[min_node]:
        new_cost = dist[min_node] + graph[min_node][neighbor]
        if new_cost < dist[neighbor]:
            dist[neighbor] = new_cost

# print result
print("Routing Table for Router", start)
for node in dist:
    print(node, "->", dist[node])



