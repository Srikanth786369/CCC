1 Error Correction Code


# sender
data = input("Enter 4-bit data: ")
print("Original Data:", data)
# place bits
h = ['0']*7
h[2] = data[0]
h[4] = data[1]
h[5] = data[2]
h[6] = data[3]
# parity bits
h[0] = str((int(h[2])+int(h[4])+int(h[6]))%2)
h[1] = str((int(h[2])+int(h[5])+int(h[6]))%2)
h[3] = str((int(h[4])+int(h[5])+int(h[6]))%2)
code = "".join(h)
print("Encoded Data:", code)
# receiver (add error at position 4)
r = list(code)
r[3] = '1' if r[3]=='0' else '0'
recv = "".join(r)
print("Received Data:", recv)
# check error
p1 = (int(r[0])+int(r[2])+int(r[4])+int(r[6]))%2
p2 = (int(r[1])+int(r[2])+int(r[5])+int(r[6]))%2
p3 = (int(r[3])+int(r[4])+int(r[5])+int(r[6]))%2
pos = p1 + p2*2 + p3*4
if pos == 0:
    print("No error")
else:
    print("Error detected at position:", pos)

